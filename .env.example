# ── Required ──────────────────────────────────────────────────────────────────

# Telegram bot token from BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID (find it via @userinfobot)
# Only this ID can use /admin_add to register other users
BOT_OWNER_ID=

# ── AI keys (at least one vision key required) ───────────────────────────────
# These are the bot owner's fallback keys — users can supply their own via /register
# If users provide their own keys, these are not used.

# Anthropic Claude (recommended)
ANTHROPIC_API_KEY=

# OpenAI GPT-4o (alternative)
# OPENAI_API_KEY=

# OpenRouter (access to many models)
# OPENROUTER_API_KEY=

# ── Optional: Kimi for cheaper text/matching (vision stays on above key) ─────
# Get key at platform.moonshot.cn → API Keys
# KIMI_API_KEY=
